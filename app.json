{
  "expo": {
    "name": "Report Hub",
    "slug": "report-hub",
    "scheme": "reporthub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/test.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/test.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.reporthub.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/test.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Report Hub to access your camera so you can capture report photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Report Hub to access your gallery to attach report photos."
        }
      ]
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}